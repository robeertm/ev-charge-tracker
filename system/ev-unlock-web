def try_auto_unlock():
    """Attempt to unlock from the stored keyfile.

    Returns True if the LUKS volume was unlocked + mounted by the call,
    False otherwise (no keyfile, wrong key, missing helper, etc.). Any
    exception falls through to the manual web UI — the auto-unlock is
    only an opt-in convenience.
    """
    try:
        r = subprocess.run(
            AUTO_UNLOCK_CMD,
            capture_output=True,
            timeout=30,
        )
        return r.returncode == 0
    except Exception:
        return False


class UnlockHandler(http.server.BaseHTTPRequestHandler):
    def log_message(self, fmt, *args):
        pass

    def do_GET(self):
        if self.path in ('/', '/unlock'):
            self._respond(200, HTML_FORM.replace('__ERROR__', ''))
        else:
            self._respond(404, '<h1>404</h1>')

    def do_POST(self):
        if self.path != '/unlock':
            self._respond(404, '<h1>404</h1>')
            return
        length = int(self.headers.get('Content-Length', '0') or '0')
        body = self.rfile.read(length).decode('utf-8', errors='replace')
        form = urllib.parse.parse_qs(body)
        passphrase = (form.get('passphrase') or [''])[0]
        if not passphrase:
            self._error('Passphrase darf nicht leer sein.')
            return
        try:
            r = subprocess.run(
                UNLOCK_CMD,
                input=passphrase.encode('utf-8'),
                capture_output=True,
                timeout=30,
            )
        except Exception as e:
            self._error(f'Interner Fehler: {e}')
            return
        if r.returncode != 0:
            err = (r.stderr or b'').decode(errors='replace').strip()
            low = err.lower()
            if 'no key' in low or 'kein schl' in low or 'keine passende' in low:
                self._error('Passphrase stimmt nicht.')
            else:
                self._error(f'Fehler: {err[:200] or "unbekannt"}')
            return
        self._respond(200, HTML_SUCCESS)
        threading.Thread(target=self._handoff, daemon=True).start()

    def _respond(self, code, body):
        data = body.encode('utf-8')
        self.send_response(code)
        self.send_header('Content-Type', 'text/html; charset=utf-8')
        self.send_header('Content-Length', str(len(data)))
        self.send_header('Cache-Control', 'no-store')
        self.end_headers()
        try:
            self.wfile.write(data)
            self.wfile.flush()
        except Exception:
            pass

    def _error(self, msg):
        err_html = f'<div class="err">{html.escape(msg)}</div>'
        self._respond(400, HTML_FORM.replace('__ERROR__', err_html))

    def _handoff(self):
        time.sleep(0.8)
        try:
            subprocess.Popen(START_CMD)
        except Exception:
            pass
        time.sleep(0.6)
        os._exit(0)


def main():
    # If the user enabled auto-unlock from inside the app, the keyfile
    # exists and unlocking is non-interactive. Try it first; on success
    # start ev-tracker.service and exit without ever serving the web UI.
    if try_auto_unlock():
        print('ev-unlock-web: auto-unlock succeeded, handing off', flush=True)
        try:
            subprocess.Popen(START_CMD)
        except Exception as e:
            print(f'ev-unlock-web: handoff start failed: {e}', flush=True)
        return

    srv = http.server.ThreadingHTTPServer(('0.0.0.0', PORT), UnlockHandler)
    print(f'ev-unlock-web: listening on 0.0.0.0:{PORT}', flush=True)
    try:
        srv.serve_forever()
    except KeyboardInterrupt:
        pass


if __name__ == '__main__':
    main()
