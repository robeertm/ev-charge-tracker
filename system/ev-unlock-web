#!/usr/bin/env python3
"""Web-based LUKS unlock helper for ev-charge-tracker VMs.

If ``/etc/ev-tracker/luks-keyfile`` exists (auto-unlock enabled by the
user from inside the app), tries to unlock from that file FIRST and
skips the web UI entirely on success. The ``ev-luks-autounlock``
wrapper is the only thing that touches the keyfile — this helper just
calls ``try-unlock`` via sudo and inspects the return code.
"""
import html
import http.server
import os
import subprocess
import threading
import time
import urllib.parse

PORT = 7654
UNLOCK_CMD = ['sudo', '-n', '/usr/local/bin/ev-unlock', '--stdin', '--no-start']
START_CMD = ['sudo', '-n', '/bin/systemctl', 'restart', 'ev-tracker.service']
AUTO_UNLOCK_CMD = ['sudo', '-n', '/usr/local/bin/ev-luks-autounlock', 'try-unlock']

